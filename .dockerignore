# ===========================================
# .dockerignore — Keep Docker context minimal
# ===========================================

# Dependencies (re-installed inside container)
node_modules
npm-debug.log*

# Next.js build output (rebuilt inside container)
.next
out

# Version control
.git
.gitignore

# Docker files (no recursion)
Dockerfile
docker-compose*.yml
.dockerignore

# IDE / Editor
.vscode
.idea
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db

# Environment files with secrets (injected at runtime, not baked in)
.env
.env.*
!.env.production.example

# CI/CD
.github
.gitlab-ci.yml

# Mobile / Capacitor (not needed for web Docker build)
android
ios
capacitor.config.ts

# Documentation
README.md
CHANGELOG.md
LICENSE
docs/

# Testing
coverage
__tests__
*.test.*
*.spec.*
jest.config.*

# Deployment scripts (not needed in image)
deploy.sh
ecosystem.config.js

# Misc
*.md
*.log
.eslintcache
.turbo
